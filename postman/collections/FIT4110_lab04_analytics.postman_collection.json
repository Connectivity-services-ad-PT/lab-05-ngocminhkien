{
  "info": {
    "name": "FIT4110_lab03_analytics",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01_Functional",
      "item": [
        {
          "name": "Check Health Status",
          "request": { "method": "GET", "url": "{{baseUrl}}/health" },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response is healthy json', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.status).to.eql('healthy');",
                  "    pm.expect(jsonData).to.have.property('timestamp');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Dashboard Summary",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": "{{baseUrl}}/api/v1/analytics/summary"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Summary contains core metrics', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('total_records');",
                  "    pm.expect(jsonData).to.have.property('system_efficiency');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "02_Auth",
      "item": [
        {
          "name": "Get Summary Without Token",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/analytics/summary" },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Missing token returns 401 or 403', function () {",
                  "    pm.expect([200, 401, 403]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "03_Negative",
      "item": [
        {
          "name": "Create Report Missing Start Date",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"end_date\": \"2026-05-24T23:59:59Z\", \"report_type\": \"iot\"}"
            },
            "url": "{{baseUrl}}/api/v1/analytics/reports"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Client error code on missing payload fields', function () {",
                  "    pm.expect([400, 422]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "04_Boundary_Reliability",
      "item": [
        {
          "name": "Query Anomalies with Invalid Page Limit",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/analytics/anomalies?page=-1&limit=500" },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Boundary validation handles bad integers', function () {",
                  "    pm.expect([400, 422]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "05_Consumer_side_Smoke",
      "item": [
        {
          "name": "Smoke Test Dependency Service IoT Health",
          "request": { "method": "GET", "url": "{{iotMockUrl}}/health" },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Upstream IoT target is reachable', function () {",
                  "    pm.expect([200, 404]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Smoke Test Dependency Service AI Vision Health",
          "request": { "method": "GET", "url": "{{aiVisionMockUrl}}/health" },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Upstream AI Vision target is reachable', function () {",
                  "    pm.expect([200, 404]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "06_Local_only_NonFunctional",
      "item": [
        {
          "name": "Check Local Latency Performance",
          "request": { "method": "GET", "url": "{{baseUrl}}/health" },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.environment.get('env') === 'local') {",
                  "    pm.test('Response time under production SLA thresholds', function () {",
                  "        pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "    });",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}